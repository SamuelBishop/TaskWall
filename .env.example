# Todoist API token
# Get yours at: Todoist → Settings → Integrations → Developer
VITE_TODOIST_API_TOKEN=your-todoist-api-token-here

# (Optional) Only show tasks from this Todoist project.
# Find the project ID in the URL: app.todoist.com/app/project/<name>-<ID>
VITE_TODOIST_PROJECT_ID=

# (Optional) Map Todoist usernames to display names.
# Format: TodoistName1:DisplayName1,TodoistName2:DisplayName2
VITE_DISPLAY_NAMES=

# (Optional) Set to "true" on the Pi to hide dev controls and run fullscreen
# VITE_KIOSK=true

# Google Calendar OAuth2 (for Calendar app)
# 1. Go to console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth2 Web Application client
# 3. Add http://localhost:3001/callback as an Authorized Redirect URI
# 4. Run: node scripts/google-auth.mjs <client-id> <client-secret>
# 5. Sign in and paste the refresh token below
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_REFRESH_TOKEN=

# (Optional) Secondary user's refresh token (e.g. spouse/partner)
# Run the auth script again while signed into their Google account
VITE_GOOGLE_REFRESH_TOKEN_SECONDARY=

# Google Calendar IDs with display names, colors, and token key.
# Format: calendarId:DisplayName:#color:tokenKey (tokenKey = primary or secondary)
# Calendar IDs are usually email addresses (found in Google Calendar → Settings → calendar)
# IMPORTANT: Wrap in double quotes so the # in hex colors isn't treated as a comment
VITE_GOOGLE_CALENDARS="sam@gmail.com:Sam:#3b82f6:primary,shane@gmail.com:Shane:#22c55e:secondary"
